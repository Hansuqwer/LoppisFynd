<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31) data extraction rules.
  Controls what gets backed up to Google cloud and what can be transferred
  during device-to-device migration.

  Policy: exclude the Drift SQLite database and scan photo cache.
  The app is offline-first and the database is the source of truth;
  restoring a stale backup could cause data conflicts.
-->
<data-extraction-rules>
    <!-- Cloud backup: exclude everything. The app manages its own sync. -->
    <cloud-backup>
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>

    <!-- Device-to-device transfer: allow settings, exclude large media. -->
    <device-transfer>
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
