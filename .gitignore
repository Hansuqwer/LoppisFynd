# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Node (used by Deno npm auto-install)
**/node_modules/

# Build outputs in subprojects
**/build/

# Generated localization output (legacy path)
lib/l10n/app_localizations*.dart

# Environment files (keep secrets out of git)
.env
.env.*
!.env.example

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android signing (never commit)
android/key.properties
android/app/*.jks

# OpenCode scratch (keep handoffs/notes only)
.sisyphus/*
!.sisyphus/README.md
!.sisyphus/handoffs/
!.sisyphus/handoffs/**
!.sisyphus/notepads/
!.sisyphus/notepads/**

# Codex local state
.codex/auth.json
.codex/log/
.codex/sessions/
*.backup-*

# Claude Code local state
.claude/settings.local.json
.claude/**/*.output
.claude/**/*.log
docs/baseline-*.json
docs/baseline-*.txt
docs/analyzer-output.txt
docs/triage-history.json
docs/platform-channels-audit.txt
