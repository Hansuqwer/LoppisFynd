# Never commit real secrets. Copy to `.env` for local dev.

# Tradera (to be used server-side via Supabase Edge Functions)
TRADERA_APP_ID=
TRADERA_APP_KEY=
TRADERA_PUBLIC_KEY=

# Supabase (safe to share anon key, but keep out of git anyway)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Edge function endpoint used by the app
TRADERA_PROXY_URL=

# Google Books API (for ISBN metadata lookup)
GOOGLE_BOOKS_API_KEY=

# Apify (for Vinted scraping)
APIFY_API_TOKEN=
VINTED_SCRAPER_ACTOR_ID=

# Bokbörsen scraper edge function URL
BOKBORSEN_SCRAPER_URL=

# Book market aggregator edge function URL
BOOK_MARKET_AGGREGATOR_URL=

# Sentry (optional, for crash reporting)
SENTRY_DSN=
