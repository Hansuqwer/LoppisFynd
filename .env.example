# Never commit real secrets. Copy to `.env` for local dev.
# Flutter dart-define vars are passed at build time, not read from .env at runtime.
# This file documents all configuration.

# ── Flutter build-time dart-defines ──
APP_ENV=dev
SUPABASE_URL=
SUPABASE_ANON_KEY=
TRADERA_PROXY_URL=
CLOUD_AI_PROXY_URL=
SENTRY_DSN=

# ── Supabase Edge Function secrets (set via `supabase secrets set`) ──
# Used by tradera-proxy
TRADERA_APP_ID=
TRADERA_APP_KEY=
TRADERA_SANDBOX=0
TRADERA_MAX_RESULT_AGE=0

# Used by tradera-proxy rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Used by cloud-ai-proxy
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Used by account-delete (auto-populated by Supabase)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=