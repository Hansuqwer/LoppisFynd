# Never commit real secrets. Copy to `.env` for local dev.

# Tradera (to be used server-side via Supabase Edge Functions)
TRADERA_APP_ID=
TRADERA_APP_KEY=
TRADERA_PUBLIC_KEY=

# Supabase (safe to share anon key, but keep out of git anyway)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Edge function endpoint used by the app
TRADERA_PROXY_URL=
